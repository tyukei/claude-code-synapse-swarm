#!/usr/bin/env bash
set -euo pipefail

# Clean up worktrees, branches, and tmux session for a swarm session.
# Usage: teardown <session> [--keep-branches]

SYNAPSE_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
export SYNAPSE_ROOT

source "${SYNAPSE_ROOT}/lib/log.sh"
source "${SYNAPSE_ROOT}/lib/worktree.sh"
source "${SYNAPSE_ROOT}/lib/tmux.sh"

session="${1:?Usage: teardown <session> [--keep-branches]}"
keep_branches=false
[[ "${2:-}" == "--keep-branches" ]] && keep_branches=true

log_section "Tearing down session: ${session}"

# Kill tmux session
tmux_kill_session "$session" 2>/dev/null || true

# Remove worktrees
roles=$(worktree_list "$session")
worktree_remove_all "$session"

# Optionally delete branches
if ! $keep_branches; then
    log_info "Deleting agent branches..."
    for role in $roles; do
        branch="swarm/${session}/${role}"
        if git -C "${SYNAPSE_ROOT}" branch -d "$branch" 2>/dev/null; then
            log_ok "Deleted branch: ${branch}"
        else
            git -C "${SYNAPSE_ROOT}" branch -D "$branch" 2>/dev/null && \
                log_warn "Force-deleted unmerged branch: ${branch}" || true
        fi
    done
else
    log_info "Keeping branches (--keep-branches)"
fi

log_ok "Teardown complete: ${session}"
