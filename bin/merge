#!/usr/bin/env bash
set -euo pipefail

# Merge agent branches back into main.
# Usage: merge <session> [--strategy sequential|octopus]

SYNAPSE_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
export SYNAPSE_ROOT

source "${SYNAPSE_ROOT}/lib/log.sh"
source "${SYNAPSE_ROOT}/lib/worktree.sh"

session="${1:?Usage: merge <session> [--strategy sequential|octopus]}"
strategy="${2:-sequential}"

log_section "Merging branches: ${session}"

roles=$(worktree_list "$session")
if [[ -z "$roles" ]]; then
    log_warn "No worktrees found for session: ${session}"
    exit 0
fi

# Ensure we're on main
cd "${SYNAPSE_ROOT}"
current_branch=$(git branch --show-current)
if [[ "$current_branch" != "main" && "$current_branch" != "master" ]]; then
    log_warn "Not on main/master branch (current: ${current_branch})"
    log_info "Please switch to main before merging."
    exit 1
fi

case "$strategy" in
    sequential)
        log_info "Strategy: sequential merge (one branch at a time)"
        for role in $roles; do
            branch="swarm/${session}/${role}"
            log_info "Merging ${branch}..."

            if git merge --no-ff "$branch" -m "swarm: merge ${role} from session ${session}"; then
                log_ok "Merged: ${role}"
            else
                log_error "Merge conflict in ${role}. Resolve manually, then re-run."
                log_info "  git merge --continue    # after resolving"
                log_info "  git merge --abort        # to cancel"
                exit 1
            fi
        done
        ;;

    octopus)
        log_info "Strategy: octopus merge (all branches at once)"
        branches=()
        for role in $roles; do
            branches+=("swarm/${session}/${role}")
        done

        if git merge --no-ff "${branches[@]}" -m "swarm: merge all agents from session ${session}"; then
            log_ok "Octopus merge successful"
        else
            log_error "Octopus merge failed. Try sequential strategy instead:"
            log_info "  bin/merge ${session} sequential"
            git merge --abort 2>/dev/null
            exit 1
        fi
        ;;

    *)
        log_error "Unknown strategy: ${strategy}. Use 'sequential' or 'octopus'."
        exit 1
        ;;
esac

log_ok "All branches merged for session: ${session}"
