#!/usr/bin/env bash
set -euo pipefail

# オーケストレーター（bin/swarm から起動される内部スクリプト）
# $CMUX_WORKSPACE_ID が自動でセットされているので cmux コマンドは現在のワークスペースに作用する

source "${SYNAPSE_ROOT}/lib/worktree.sh"

# ── 右ペインを作成してワーカー用に確保 ──────────────────────────
PANE_BEFORE=$(cmux list-panes 2>/dev/null | grep "^pane:" | sort)
cmux new-pane --direction right 2>/dev/null
sleep 0.4
PANE_AFTER=$(cmux list-panes 2>/dev/null | grep "^pane:" | sort)
RIGHT_PANE=$(comm -13 <(echo "$PANE_BEFORE") <(echo "$PANE_AFTER") | tail -1)

# 左ペイン（オーケストレーター）にフォーカスを戻す
LEFT_PANE=$(echo "$PANE_BEFORE" | head -1)
cmux focus-pane --pane "$LEFT_PANE" 2>/dev/null || true

# ── ユーザー入力 ──────────────────────────────────────────────
clear
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "  Synapse Swarm"
echo "  対象リポジトリ: ${TARGET}"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""
echo -n "どんな作業をしますか？ > "
read -r TASK
echo ""

if [[ -z "$TASK" ]]; then
    echo "タスクが入力されていません。終了します。"
    read -p "Enterで閉じる..."
    exit 0
fi

echo "タスクを分解中..."

# ── Claude でタスクを分解 ──────────────────────────────────────
PROMPT_TEMPLATE=$(cat "${SYNAPSE_ROOT}/roles/orchestrator.md")
PROMPT="${PROMPT_TEMPLATE//\{\{TASK\}\}/$TASK}"

RAW=$(cd "$TARGET" && claude \
    --model claude-sonnet-4-6 \
    --dangerously-skip-permissions \
    --print "$PROMPT" 2>/dev/null)

JSON=$(python3 - "$RAW" <<'PYEOF'
import sys, re, json
text = sys.argv[1] if len(sys.argv) > 1 else sys.stdin.read()
m = re.search(r'```(?:json)?\s*(\{.*?\})\s*```', text, re.DOTALL)
if m:
    print(m.group(1))
else:
    m = re.search(r'\{.*\}', text, re.DOTALL)
    if m:
        print(m.group(0))
PYEOF
)

if [[ -z "$JSON" ]]; then
    echo "エラー: タスクの分解に失敗しました。"
    echo "$RAW"
    read -p "Enterで閉じる..."
    exit 1
fi

# ── サブタスク一覧を表示 ──────────────────────────────────────
echo ""
echo "サブタスク:"
python3 - "$JSON" <<'PYEOF'
import sys, json
data = json.loads(sys.argv[1])
for i, t in enumerate(data['tasks'], 1):
    print(f"  {i}. [{t['id']}] {t['description']}")
PYEOF
echo ""
echo "エージェントを起動中..."

# ── 各ワーカーを右ペインのサーフェス（タブ）として起動 ──────────
python3 - "$JSON" <<'PYEOF' | while IFS=$'\t' read -r task_id task_desc; do
import sys, json
data = json.loads(sys.argv[1])
for t in data['tasks']:
    print(t['id'] + '\t' + t['description'])
PYEOF
    worktree_path=$(worktree_create "$SESSION" "$task_id" "$TARGET")

    # 右ペインに新しいサーフェス（タブ）を作成
    SURF_BEFORE=$(cmux list-pane-surfaces --pane "$RIGHT_PANE" 2>/dev/null | grep "^surface:" | sort)
    cmux new-surface --pane "$RIGHT_PANE" --type terminal 2>/dev/null
    sleep 0.8  # シェル起動待ち
    SURF_AFTER=$(cmux list-pane-surfaces --pane "$RIGHT_PANE" 2>/dev/null | grep "^surface:" | sort)
    NEW_SURF=$(comm -13 <(echo "$SURF_BEFORE") <(echo "$SURF_AFTER") | tail -1)

    # タブ名をタスクIDに設定
    cmux rename-tab --surface "$NEW_SURF" "$task_id" 2>/dev/null || true

    # ワーカーコマンドを送信
    WORKER_CMD="SYNAPSE_ROOT=$(printf '%q' "$SYNAPSE_ROOT") bash $(printf '%q' "${SYNAPSE_ROOT}/bin/_worker") $(printf '%q' "$worktree_path") $(printf '%q' "$task_id") $(printf '%q' "$task_desc")"
    cmux send --surface "$NEW_SURF" "$WORKER_CMD"
    cmux send-key --surface "$NEW_SURF" Enter

    echo "  起動: ${task_id}"
done

echo ""
echo "右ペインのタブで各エージェントの作業を確認できます。"
echo ""
read -p "Enterで閉じる..."
