#!/usr/bin/env bash
set -euo pipefail

# Collect results from all agent worktrees into the output directory.
# Usage: collect <session>

SYNAPSE_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
export SYNAPSE_ROOT

source "${SYNAPSE_ROOT}/lib/log.sh"
source "${SYNAPSE_ROOT}/lib/worktree.sh"

session="${1:?Usage: collect <session>}"

log_section "Collecting results: ${session}"

output_dir="${SYNAPSE_ROOT}/output/${session}"
mkdir -p "$output_dir"

# Collect artifacts from each worktree
roles=$(worktree_list "$session")
if [[ -z "$roles" ]]; then
    log_warn "No worktrees found for session: ${session}"
    exit 0
fi

for role in $roles; do
    wt_path=$(worktree_path "$session" "$role")
    role_output="${output_dir}/${role}"
    mkdir -p "$role_output"

    log_info "Collecting from ${role}..."

    # Copy report files
    for report in PLAN.md ARCHITECTURE.md CODER_REPORT.md TEST_REPORT.md REVIEW.md DOCS_REPORT.md MEMORY.md; do
        if [[ -f "${wt_path}/${report}" ]]; then
            cp "${wt_path}/${report}" "${role_output}/"
            log_ok "  ${report}"
        fi
    done

    # Record the git log for this branch
    git -C "$wt_path" log --oneline -20 > "${role_output}/git-log.txt" 2>/dev/null || true

    # Record the diff from main
    git -C "$wt_path" diff main --stat > "${role_output}/diff-stat.txt" 2>/dev/null || true
done

# Generate a combined summary
summary="${output_dir}/SUMMARY.md"
{
    echo "# Swarm Session: ${session}"
    echo ""
    echo "## Agents"
    echo ""
    for role in $roles; do
        role_output="${output_dir}/${role}"
        echo "### ${role}"
        echo ""
        if [[ -f "${role_output}/diff-stat.txt" ]]; then
            echo '```'
            cat "${role_output}/diff-stat.txt"
            echo '```'
        else
            echo "_No changes_"
        fi
        echo ""
    done

    echo "## Branches"
    echo ""
    for role in $roles; do
        echo "- \`swarm/${session}/${role}\`"
    done
    echo ""
    echo "## Next Steps"
    echo "1. Review each agent's output in \`output/${session}/\`"
    echo "2. Merge branches: \`bin/merge ${session}\`"
    echo "3. Clean up: \`bin/teardown ${session}\`"
} > "$summary"

log_ok "Summary written to: ${summary}"
log_section "Results collected: ${output_dir}"
