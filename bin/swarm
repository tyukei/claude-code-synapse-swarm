#!/usr/bin/env bash
set -euo pipefail

# Synapse Swarm — Main orchestrator
# Spawns multiple Claude Code agents in mux panes, each in its own worktree.
# Supports tmux and cmux backends (auto-detected).
#
# Usage:
#   swarm <task_file>                  — Run from a task YAML file
#   swarm --task "description" [roles] — Run with inline task description
#   swarm --help                       — Show help

SYNAPSE_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
export SYNAPSE_ROOT

source "${SYNAPSE_ROOT}/lib/log.sh"
source "${SYNAPSE_ROOT}/lib/worktree.sh"
source "${SYNAPSE_ROOT}/lib/task.sh"

# ── Parse arguments ──────────────────────────────────────────────
usage() {
    cat <<'USAGE'
Synapse Swarm — Multi-agent Claude Code orchestrator

Usage:
  swarm <task_file.yaml>
  swarm --task "Build a REST API" [--roles planner,coder,tester]
  swarm --task "Fix bug #123" --roles coder,reviewer

Options:
  --task, -t     Inline task description
  --roles, -r    Comma-separated list of roles (default: planner,architect,coder,tester,reviewer)
  --model, -m    Model override for all agents (default: opus)
  --mux          Multiplexer backend: auto | tmux | cmux | none (default: auto)
  --no-mux       Run agents sequentially without a multiplexer
  --help, -h     Show this help

Multiplexer backends:
  auto   Prefer cmux if running, fall back to tmux, then sequential
  cmux   Use cmux (workspaces + sidebar status)
  tmux   Use tmux (windows + panes)
  none   Sequential mode, no multiplexer required
USAGE
    exit 0
}

TASK_FILE=""
TASK_DESC=""
ROLES=""
MODEL="opus"
USE_MUX=true

while [[ $# -gt 0 ]]; do
    case "$1" in
        --task|-t)    TASK_DESC="$2"; shift 2 ;;
        --roles|-r)   ROLES="$2"; shift 2 ;;
        --model|-m)   MODEL="$2"; shift 2 ;;
        --mux)        export MUX_BACKEND="$2"; shift 2 ;;
        --no-mux)     USE_MUX=false; shift ;;
        --help|-h)    usage ;;
        *)
            if [[ -f "$1" ]]; then
                TASK_FILE="$1"
            else
                log_error "Unknown argument or file not found: $1"
                exit 1
            fi
            shift ;;
    esac
done

# Load mux abstraction (auto-detects cmux vs tmux)
source "${SYNAPSE_ROOT}/lib/mux.sh"

# Disable mux if explicitly requested or none available
if ! $USE_MUX || ! mux_available; then
    USE_MUX=false
    export MUX_BACKEND=none
fi

# ── Resolve task description and roles ───────────────────────────
if [[ -n "$TASK_FILE" ]]; then
    TASK_DESC=$(task_get_description "$TASK_FILE")
    if [[ -z "$ROLES" ]]; then
        ROLES=$(task_get_roles "$TASK_FILE" | tr ' ' ',')
    fi
fi

if [[ -z "$TASK_DESC" ]]; then
    log_error "No task provided. Use --task or provide a task file."
    echo ""
    usage
fi

if [[ -z "$ROLES" ]]; then
    ROLES="planner,architect,coder,tester,reviewer"
fi

# Convert comma-separated to array
IFS=',' read -ra ROLE_ARRAY <<< "$ROLES"

# ── Generate session ID ─────────────────────────────────────────
SESSION="synapse-$(date +%Y%m%d-%H%M%S)"

log_section "Synapse Swarm"
log_info "Session:  ${SESSION}"
log_info "Task:     ${TASK_DESC}"
log_info "Roles:    ${ROLES}"
log_info "Model:    ${MODEL}"
log_info "Mux:      $(mux_backend)"
echo ""

# ── Ensure we have a clean base ──────────────────────────────────
if [[ -n "$(git -C "${SYNAPSE_ROOT}" status --porcelain)" ]]; then
    log_warn "Working tree has uncommitted changes. Agents branch from current HEAD."
fi

# ── Group roles by phase ────────────────────────────────────────
declare -A PHASE_ROLES
for role in "${ROLE_ARRAY[@]}"; do
    phase=$(task_get_phase "$role")
    PHASE_ROLES[$phase]="${PHASE_ROLES[$phase]:-} ${role}"
done

# Sort phases
PHASES=($(echo "${!PHASE_ROLES[@]}" | tr ' ' '\n' | sort -n))

# ── Run agents ──────────────────────────────────────────────────
if $USE_MUX; then
    # Mux mode: create session and spawn panes/workspaces
    mux_create_session "$SESSION"

    for phase in "${PHASES[@]}"; do
        roles_in_phase=(${PHASE_ROLES[$phase]})
        log_section "Phase ${phase}: ${roles_in_phase[*]}"

        for role in "${roles_in_phase[@]}"; do
            spawn_cmd="${SYNAPSE_ROOT}/bin/spawn-agent ${SESSION} ${role} '${TASK_DESC}' ${MODEL}"
            mux_spawn_pane "$SESSION" "$role" "$spawn_cmd"
        done

        # Wait for this phase before starting the next
        if [[ "$phase" != "${PHASES[-1]}" ]]; then
            log_info "Waiting for phase ${phase} to complete..."
            mux_wait_all "$SESSION" "${roles_in_phase[@]}"
        fi
    done

    log_ok "All agents spawned."
    echo ""

    case "$(mux_backend)" in
        cmux)
            echo "Agents are running in cmux workspaces."
            echo "Workspace names: ${SESSION}/<role>"
            echo ""
            echo "Sidebar shows live status for each agent."
            ;;
        tmux)
            echo "  tmux attach -t ${SESSION}"
            echo ""
            echo "Useful commands:"
            echo "  Ctrl-b n/p  — Next/previous agent pane"
            echo "  Ctrl-b d    — Detach from session"
            ;;
    esac

    echo ""
    echo "When done, collect results:"
    echo "  bin/collect ${SESSION}"
    echo "  bin/merge ${SESSION}"
    echo ""

else
    # Sequential mode: run agents one by one
    for phase in "${PHASES[@]}"; do
        roles_in_phase=(${PHASE_ROLES[$phase]})
        log_section "Phase ${phase}: ${roles_in_phase[*]}"

        for role in "${roles_in_phase[@]}"; do
            "${SYNAPSE_ROOT}/bin/spawn-agent" "$SESSION" "$role" "$TASK_DESC" "$MODEL"
        done
    done

    log_ok "All agents completed sequentially."
    log_info "Collecting results..."
    "${SYNAPSE_ROOT}/bin/collect" "$SESSION"
fi

log_section "Session complete: ${SESSION}"
