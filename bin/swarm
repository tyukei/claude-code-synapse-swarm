#!/usr/bin/env bash
set -euo pipefail

# Synapse Swarm — タスクを並列エージェントで実行する
# 使い方: cd /path/to/your/project && /path/to/swarm/bin/swarm

SYNAPSE_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
TARGET="$(pwd)"
SESSION="swarm-$(date +%H%M%S)"

if ! command -v cmux &>/dev/null; then
    echo "エラー: cmux が必要です"
    exit 1
fi

if ! command -v claude &>/dev/null; then
    echo "エラー: Claude CLI が必要です"
    exit 1
fi

# オーケストレーターを新しい cmux ワークスペースで起動
cmux new-workspace \
    --command "SYNAPSE_ROOT=$(printf '%q' "$SYNAPSE_ROOT") TARGET=$(printf '%q' "$TARGET") SESSION=$(printf '%q' "$SESSION") bash $(printf '%q' "${SYNAPSE_ROOT}/bin/_orchestrate")" \
    --name "swarm: orchestrator"
