#!/usr/bin/env bash
set -euo pipefail

# Spawn a single Claude Code agent in a worktree with a role prompt.
# Usage: spawn-agent <session> <role> <task_description> [model]

SYNAPSE_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
export SYNAPSE_ROOT

source "${SYNAPSE_ROOT}/lib/log.sh"
source "${SYNAPSE_ROOT}/lib/worktree.sh"
source "${SYNAPSE_ROOT}/lib/task.sh"
source "${SYNAPSE_ROOT}/lib/mux.sh"

session="${1:?Usage: spawn-agent <session> <role> <task_description> [model]}"
role="${2:?Usage: spawn-agent <session> <role> <task_description> [model]}"
task_desc="${3:?Usage: spawn-agent <session> <role> <task_description> [model]}"
model="${4:-opus}"

log_section "Agent: ${role}"

# ── Create worktree ──────────────────────────────────────────────
worktree_path=$(worktree_create "$session" "$role")
if [[ -z "$worktree_path" ]]; then
    log_error "Failed to create worktree for ${role}"
    mux_mark_done "$session" "$role" "error"
    exit 1
fi

# ── Resolve and render prompt ─────────────────────────────────────
template="${SYNAPSE_ROOT}/roles/${role}.md"
if [[ ! -f "$template" ]]; then
    log_error "No prompt template found: ${template}"
    mux_mark_done "$session" "$role" "error"
    exit 1
fi

prompt=$(task_render_prompt "$template" "$task_desc")

# ── Log invocation ───────────────────────────────────────────────
log_to_file "${SYNAPSE_ROOT}/output/${session}.log" "Spawning ${role} in ${worktree_path}"

# Signal start in cmux sidebar
mux_set_progress "$session" "$role" "0.1" "starting"

# ── Run Claude Code ──────────────────────────────────────────────
cd "$worktree_path"

log_info "Running Claude Code as ${role} (model: ${model})..."
mux_set_progress "$session" "$role" "0.3" "running"

agent_exit=0
claude --model "$model" --dangerously-skip-permissions --print "$prompt" \
    2>&1 | tee "${SYNAPSE_ROOT}/output/${session}-${role}.log" || agent_exit=$?

if [[ $agent_exit -ne 0 ]]; then
    log_warn "${role}: Claude exited with code ${agent_exit}"
fi

# ── Commit changes ───────────────────────────────────────────────
mux_set_progress "$session" "$role" "0.8" "committing"

if [[ -n "$(git -C "$worktree_path" status --porcelain)" ]]; then
    git -C "$worktree_path" add -A
    git -C "$worktree_path" commit -m "swarm(${role}): automated changes from ${role} agent

Session: ${session}
Role: ${role}"
    log_ok "${role}: changes committed on branch swarm/${session}/${role}"
else
    log_info "${role}: no changes to commit"
fi

# ── Signal completion ────────────────────────────────────────────
mux_set_progress "$session" "$role" "1.0" "done"

if [[ $agent_exit -eq 0 ]]; then
    mux_mark_done "$session" "$role" "success"
    log_ok "Agent ${role} completed successfully"
else
    mux_mark_done "$session" "$role" "error"
    log_warn "Agent ${role} completed with errors"
fi
