{
  "name": "Synapse Swarm",
  "build": {
    "dockerfile": "Dockerfile"
  },

  // Pass ANTHROPIC_API_KEY from the host environment into the container.
  // Set it in your shell: export ANTHROPIC_API_KEY=sk-ant-...
  "containerEnv": {
    "ANTHROPIC_API_KEY": "${localEnv:ANTHROPIC_API_KEY}",
    "MUX_BACKEND": "tmux"
  },

  // Mount the user's git config so commits have correct authorship
  "mounts": [
    "source=${localEnv:HOME}/.gitconfig,target=/root/.gitconfig,type=bind,consistency=cached"
  ],

  "postCreateCommand": "chmod +x bin/* && git config --global --add safe.directory /workspaces/claude-code-synapse-swarm",

  // Recommended VSCode extensions for working with this repo
  "customizations": {
    "vscode": {
      "extensions": [
        "foxundermoon.shell-format",
        "timonwong.shellcheck",
        "redhat.vscode-yaml"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash",
        "files.eol": "\n"
      }
    }
  },

  "remoteUser": "root"
}
